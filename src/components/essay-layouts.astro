---

import PageWrapper from './page-wrapper.astro';
import ContextSection from './context-section.astro';
import Navigation from './navigation.astro';
import Footer from './footer.astro';

const { frontmatter } = Astro.props;

---


<PageWrapper>
<Navigation />     
     <ContextSection>

          


     <div class="content-links">
          <span> {frontmatter.title} </span>
          <span class="link-details"> / </span>
          <time class="link-details"> {frontmatter.date} </time>
          <span class="link-details"> / </span>
          <span class="link-details"> No.35 </span>
     </div>
     <hr>
     <slot /> 
     <hr>
     <button onclick="history.back()" aria-label="Go back" class="primary-button"> Back </button>

      
     </ContextSection>
<Footer />
</PageWrapper>


<style>

     .content-links:hover{
     cursor: default;
     background: #FAFAFA;}

</style>