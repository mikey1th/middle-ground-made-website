---

import '../styles/global.css';
import {getCollection} from 'astro:content';
import {Image} from 'astro:assets';


import type { CollectionEntry } from 'astro:content';
const entries: CollectionEntry<'compendium'>[] = (await getCollection('compendium')).sort((a, b) => b.data.id - a.data.id);

---



<div class="all-compendium-entries">
    {entries.map((entry, index) => (
        <div class="compendium-entry"> 
                {/* the div below renders the unconditonal header info */}
                <div class="compendium-header-info">
                    <div class="content-bubble">
                        <span> {entry.data.title} </span>
                        <div class="link-details header">
                            <span class="link-details header hide-mobile"> / </span>
                            <span class="link-details header"> {entry.data.date} </span>
                            <span class="link-details header"> / </span>
                            <span class="link-details header"> {entry.data.id} </span>
                        </div>
                    </div>
                        {/* this stuff is conditionally rendered appears to the right of the link. The js conditionally renders the entire div.
                        Then the categories are themselves conditionally rendered. */}
                        {(entry.data.openNote || entry.data.project) && (
                        <div class="content-links mobile-row"> 
                            {entry.data.openNote && (
                            <a href= {entry.data.openNote} class="link-details"> Note</a>
                            )}
                            {entry.data.openNote && entry.data.project && (
                            <span class="link-details"> / </span>
                            )}
                            {entry.data.project && (
                            <a href= {entry.data.project} class="link-details"> Project</a>
                            )}
                        </div>
                        )}
                </div>
                {/* Wanted to do a conditionalky rendered light border, didnt look that great not worth the effort but keeping the code just in case.
                To render in the alt border change the boolean on data to be true. */}
                {entry.data.lightBorder ? (
                    <Image class="image-light-border"
                        src={entry.data.image}
                        alt={entry.data.title}
                        width={entry.data.image.width}
                        height={entry.data.image.height}
                        loading={index === 0 ? "eager" : "lazy"} />
                ) : (
                    <Image class="image-dark-border"
                        src={entry.data.image}
                        alt={entry.data.title}
                        width={entry.data.image.width}
                        height={entry.data.image.height}
                        loading={index === 0 ? "eager" : "lazy"} />
                )}
                <h3>{entry.data.description} </h3>

        </div>       
    ))}
</div>

<p>{entries.length}</p>


<style>
    .all-compendium-entries{
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 30px
    }

    .compendium-entry{
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 20px;
    border-bottom: 1px solid #E8E8E8;
    padding-bottom: 20px;
    }

    h3 {
    font-size: .90rem;
    font-weight: 400;
    }

    .compendium-header-info{
    display: inline-flex;
    gap: 10px;
    width: fit-content;
    }

    .link-details{
    color: #2d2d2d;
    }

    .link-details:hover{
    font-weight: 500;
    color: #2d2d2d;
    }

    .link-details.header:hover{
    pointer-events: none;
    font-weight: 300;
    }

    /* MOBILE VIEWPORT */

    @media (max-width: 768px) {


        .compendium-header-info{
            display: flex;
            flex-direction: column;
            align-items: start;
            width: 100%;
        }

        .all-snippets{
            display: flex;
            gap: 25px;
            flex-direction: column;
        }


    }

</style>
