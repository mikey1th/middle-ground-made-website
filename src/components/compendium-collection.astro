---

import '../styles/global.css';
import {getCollection} from 'astro:content';
import {Image} from 'astro:assets';


import type { CollectionEntry } from 'astro:content';
const entries: CollectionEntry<'compendium'>[] = (await getCollection('compendium')).sort((a, b) => b.data.id - a.data.id);

---



<div class="all-compendium-entries">

    {entries.map((entry, index) => (
        <div class="compendium-entry"> 

            <div class="above-image">
                <div class="date-details">
                    <span> {entry.data.date} </span>
                    <span> / </span>
                    <span> {entry.data.id} </span>
                </div>
                <span class="compendium-project-title"> {entry.data.title} </span>
                <p class="compendium-description">{entry.data.description} </p>      
            </div>
          

            <Image class="image-dark-border"
                src={entry.data.image}
                alt={entry.data.title}
                width={entry.data.image.width}
                height={entry.data.image.height}
                loading={index === 0 ? "eager" : "lazy"} />


            {/* CONDITIONAL LINKS (BELOW) */}
                {(entry.data.openNote || entry.data.project) && (
                    <div class="info-bubble"> 
                        {entry.data.openNote && ( <a href= {entry.data.openNote} class="bold-hover"> Note</a> )}
                        {entry.data.openNote && entry.data.project && ( <span class="bold-hover"> / </span> )}
                        {entry.data.project && ( <a href= {entry.data.project} class="bold-hover"> Project</a> )}
                    </div>
                )}   
        </div>
    ))}

</div>

<p>{entries.length}</p>


<style>

    .all-compendium-entries{
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 2.5rem
    }

    .compendium-entry{
    display: flex;
    flex-direction: column;
    width: 100%;
    border-radius: 10px;
    gap: 2rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    border-bottom: 1px solid var(--line-gray);
    padding-bottom: 2.5rem;
    }


    .above-image{
    display: flex;
    flex-direction: column;
    gap: .15rem;
    }

    .conditional-details{
    display: flex;
    flex-direction: row;
    }


    h3 {
    font-size: .85rem;
    font-weight: 400;
    }

    /* MOBILE VIEWPORT */

    @media (max-width: 768px) {


        .compendium-header-info{
            display: flex;
            flex-direction: column;
            align-items: start;
            width: 100%;
        }

        .all-snippets{
            display: flex;
            gap: 25px;
            flex-direction: column;
        }


    }

</style>
