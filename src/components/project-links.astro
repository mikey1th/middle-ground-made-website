---

import '../styles/global.css';
import {getCollection} from 'astro:content';
import {Image} from 'astro:assets';


import type { CollectionEntry } from 'astro:content';
const additions: CollectionEntry<'projects'>[] = (await getCollection('projects')).sort((a, b) => b.data.id - a.data.id);


const allProjects = await getCollection('projects');
const tags = [...new Set(allProjects.flatMap(p => p.data.tags ?? []))].sort();

---


<div class="filter-and-projects">

<div class="project-tag-filters"> 
    {tags.map(tag => (
    <a href ={`/project-archive/type/${tag}`} class="filter-by-tag">{tag}</a>
    ))}
</div>

<hr>

<div class="all-project-additions">
    {additions.map((project) => (
        <div class="project-entry"> 
            {/* the div below renders the unconditonal header info */}
            <div class="project-header-info">
                <div class="content-bubble">
                    <span> {project.data.title} </span>
                    <span class="link-details header"> / </span>
                    <span class="link-details header"> {project.data.date} </span>
                    <span class="link-details header"> / </span>
                    <span class="link-details header"> {project.data.id} </span>
                    <span class="link-details header"> / </span>
                    <span class="link-details header"> {project.data.displayTag} </span>
                </div>
            </div>
                <a href={`/project-archive/${project.slug}`}>
                <Image src={project.data.coverImage} alt={project.data.title} />    
                </a>
        </div>
    ))}
</div>

</div>







<style>

    .filter-and-projects{
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 30px;
    }


    .all-project-additions{
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 30px
    }

    .project-entry{
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 20px;
    padding-bottom: 30px;
    border-bottom: 1px solid #E8E8E8
    }

    .project-entry img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    transition: filter 0.3s ease;
    outline: 1px solid rgba(0, 0, 0, 0.1);
    outline-offset: -1px;
    }

    .project-entry img:hover {
    filter: brightness(0.75);
    }

    .project-header-info{
    display: inline-flex;
    gap: 10px;
    width: fit-content;
    }

    .project-tag-filters{
    display: inline-flex;
    gap: 10px;
    width: fit-content;
    }

</style>
