<style>

    .list-item-title.large{
    font-size: .95rem;
    color: #2d2d2d;
    font-weight: 500;

    }

    .list-item-title{
    font-weight: 400;
    }

    .list-item-title.large:hover{
    text-decoration: none;
    cursor: default;
    }

    .items-wrapper{
    display: flex;
    flex-direction: column;
    gap: 30px;
    }

    .all-map-list-items:last-child {
    margin-bottom: 15px;
    }


    .all-map-list-items{
    display: flex;
    flex-direction: column;
    gap: 15px;
    border: 1px solid var(--line-gray);
    border-radius: 10px;
    padding: 20px;
    }

    a {
    text-decoration: none;
    color: inherit;
    }




</style>