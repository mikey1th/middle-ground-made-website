---

import '../styles/global.css';
import stacks from '../data/stacks-data.js';
const apparel = stacks.filter((entry) => entry.type === "apparel");
const objects = stacks.filter((entry) => entry.type === "object");
const books = stacks.filter((entry) => entry.type === "book");


{/* types: apparel, objects, books */}

---

<div class="items-wrapper">

<section id=apparel class="all-map-list-items">
    <span class="list-item-title large"> Things you can wear </span>
    <hr>
    {apparel.map((item) => (
        <div>
            <div class="text-list-item">
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="list-item-title"> {item.title} </a>
                <div class="list-item-details">
                    <span> / </span>            
                    <span> {item.type} </span>
                </div>
            </div>
        </div>
    ))}
    </section>


<section id=apparel class="all-map-list-items">
    <span class="list-item-title large"> Things you can use </span>
    <hr>
    {objects.map((item) => (
        <div>
            <div class="text-list-item">
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="list-item-title"> {item.title} </a>
                <div class="list-item-details">
                    <span> / </span>            
                    <span> {item.type} </span>
                </div>
            </div>
        </div>
    ))}
    </section>


<section id=apparel class="all-map-list-items">
    <span class="list-item-title large"> Things you can read </span>
    <hr>
    {books.map((item) => (
        <div>
            <div class="text-list-item">
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="list-item-title"> {item.title} </a>
                <div class="list-item-details">
                    <span> / </span>            
                    <span> {item.type} </span>
                </div>
            </div>
        </div>
    ))}
    </section>


</div>


