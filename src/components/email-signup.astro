---

import '../styles/global.css'



---


<form id="middle-ground-newsletter-signup-form">
  <input id="first-name" type="text" placeholder="First Name" autocomplete="given-name" required />
  <input id="email" type="email" placeholder="Email " autocomplete="email" required />
  <button type="submit">Subscribe</button>
</form>





<script>
  const form = document.getElementById('middle-ground-newsletter-signup-form');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const firstName = (document.getElementById('first-name') as HTMLInputElement).value;
      const email = (document.getElementById('email') as HTMLInputElement).value;

      const FORM_ID = '6042195';
      const API_KEY = 'Sq9NzV-AaTTHij-o42DYgA';

      try {
        const response = await fetch(`https://api.convertkit.com/v3/forms/${FORM_ID}/subscribe`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            api_key: API_KEY,
            first_name: firstName,
            email: email,
          }),
        });

        const data = await response.json();

        if (data.subscription) {
          form.innerHTML = '<p>Thanks for joining the club! Please check your email to confirm your subscription! </p>';
        } else {
          form.innerHTML = '<p>Something went wrong — refresh this page to try again.</p>';
        }
      } catch (err) {
        form.innerHTML = '<p>Something went wrong — please try again.</p>';
      }
    });
  }
</script>

    







<style is:global>

    form {
        display: flex;
        gap: 20px;
        justify-content: space-between;
        align-items: center;
        font-family: "Atkinson Hyperlegible Mono";
        font-weight: 400;
        text-transform: uppercase;
        width: 100%
    }

    form p {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-family: "Atkinson Hyperlegible Next";
        font-weight: 500;
        font-size: .80rem;
        text-transform: none;
    }


    input {
        padding: .75rem 1rem;
        border: 1px solid #E8E8E8;
        background: transparent;
        font-family: inherit;
        text-transform: inherit;
        font-size: .65rem;
        color: inherit;
        border-radius: 50px;
        letter-spacing: .1rem;
        width: 100%
    }

    button {
        padding: .75rem 1rem;
        letter-spacing: .1rem;
        font-family: "Atkinson Hyperlegible Mono";
        text-transform: inherit;
        font-size: .65rem;
        font-weight: 400;
        border-radius: 50px;
        background: #FFA800;
        color: #ffffff;
        border: none;
        width: fit-content;
        transition: background-color .5s ease;
    }


    button:hover {
        font-weight: 500;
        cursor: pointer;
        background-color: #2D2D2D;
    }


    input:focus{
        outline: none;
        background: #FAFAFA;
    }



    {/* MOBILE VIEWPORT */}

    @media (max-width: 768px) {

    form {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    button{
        width: 100%;
        text-align: left;
    }

    }

</style>