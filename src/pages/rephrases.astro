---

import '../styles/global.css';
import Navigation from '../components/navigation.astro'
import ContextSectionFooter from '../components/context-section-footer.astro';
import PageWrapper from '../components/page-wrapper.astro';
import ContextSection from '../components/context-section.astro';
import BackButton from '../components/back-button.astro';
import RephrasesCollection from '../components/rephrases-collection.astro';

import rephrases from "../data/rephrases-data.js";
const count = rephrases.length;


const pageTitle = "Rephrases";


---


<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="icon" href="/favicon.ico?v=2" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
	</head>
	<body>
	<PageWrapper>
	<Navigation />
	<ContextSection>
	<h2>{pageTitle}</h2>
	<hr>
	<p> 
		Rephrases are short bits of writing that help me rethink common trains of thought. I created this list to both highlight a problem and provide a solution. As with all things on my website this list is a work in progress and with time will grow and change.
    </p>
	<p class="note">
    [{count}] Contradictions incoming
    </p>
	</ContextSection>

	<ContextSection>
	<RephrasesCollection/>
	<BackButton/>	
	</ContextSection>
	<ContextSectionFooter/>
	</PageWrapper>
	
	</body>
</html>