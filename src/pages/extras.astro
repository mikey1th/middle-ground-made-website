---

import '../styles/global.css';
import Navigation from '../components/navigation.astro'
import ContextSectionFooter from '../components/context-section-footer.astro';
import PageWrapper from '../components/page-wrapper.astro';
import ContextSection from '../components/context-section.astro';
import ContextSectionLinks from '../components/context-section-links.astro'



const pageTitle = "Extras — Middle Ground Made";


---


<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="icon" href="/favicon.ico?v=2" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

		<meta property="og:title" content="Middle Ground Made" />
		<meta property="og:description" content="Heirloom design studio." />
		<meta property="og:image" content="https://middlegroundmade.com/mg-social-share.webp" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Middle Ground Made" />
		<meta name="twitter:description" content="Heirloom design studio." />
		<meta name="twitter:image" content="https://middlegroundmade.com/mg-social-share.webp" />

	</head>
	<body>
	<PageWrapper>
	<Navigation />
	<ContextSection>
	<h2>Extras</h2>
	<hr>
	<p> If this website is my digital backyard, these pages are the tools or other random things I've accumulated over the years but can't quite get rid of.</p>
	<ContextSectionLinks>
		<a href="/bookshelf" class ="primary-button"> Bookshelf </a>
        <a href="/gallery" class ="primary-button"> Gallery </a>
		<a href="/old-gold" class ="primary-button"> Old Gold </a>
		<a href="https://middlegroundmade.bigcartel.com/" class ="primary-button" target="_blank" rel="noopener noreferrer"> Merch (↗)</a>
	</ContextSectionLinks>
	</PageWrapper>
	<ContextSectionFooter />
	</body>
</html>



