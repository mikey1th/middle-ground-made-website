---

import '../styles/global.css';
import Navigation from '../components/navigation.astro'
import ContextSectionFooter from '../components/context-section-footer.astro';
import PageWrapper from '../components/page-wrapper.astro';
import ContextSection from '../components/context-section.astro';
import BackButton from '../components/back-button.astro';
import OldGoldLayout from '../components/old-gold-layout.astro';
import { getCollection } from 'astro:content';
const additions = await getCollection('oldGold');


const pageTitle = "Old Gold — Middle Ground Made";


---


<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="icon" href="/favicon.ico?v=2" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		
		<meta property="og:title" content="Middle Ground Made" />
		<meta property="og:description" content="Heirloom design studio." />
		<meta property="og:image" content="https://middlegroundmade.com/mg-social-share.webp" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Middle Ground Made" />
		<meta name="twitter:description" content="Heirloom design studio." />
		<meta name="twitter:image" content="https://middlegroundmade.com/mg-social-share.webp" />
	</head>
	<body>
	<PageWrapper>
	<Navigation />

	<ContextSection>
	<h2>Old Gold</h2>
	<hr>
	<p> Every good designer has a cache of old deisgn specimens. Some limit thier collection to shirts, or hats, or books. 
		I'm less picky, anything that's old and but well-designed gets added to the collection. </p>
    <p class="note">
    [{additions.length}] Entries In no apparent order
    </p>
	</ContextSection>

	<ContextSection>
	<OldGoldLayout/>
	<BackButton/>
	</ContextSection>
	
	<ContextSectionFooter />

	<PageWrapper/>
	</body>
</html>