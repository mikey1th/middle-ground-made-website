---

import '../styles/global.css';
import Navigation from '../components/navigation.astro'
import ContextSectionFooter from '../components/context-section-footer.astro';
import PageWrapper from '../components/page-wrapper.astro';
import ContextSection from '../components/context-section.astro';
import BackButton from '../components/back-button.astro';
import OldGoldLayout from '../components/old-gold-layout.astro';


const pageTitle = "Old Gold";


---


<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="icon" href="/favicon.ico?v=2" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
	</head>
	<body>
	<PageWrapper>
	<Navigation />

	<ContextSection>
	<h2>{pageTitle}</h2>
	<hr>
	<p> Every good designer hasa cache of old deisgn specimens. Some people limit thier collection to shirts, or hats, or books. 
		I'm less picky, anything that's old and but well-designed gets added to the collection. </p>
    <p class="note">
    * In no apparent order
    </p>
	</ContextSection>

	<ContextSection>
	<OldGoldLayout/>
	<BackButton/>
	</ContextSection>
	
	<ContextSectionFooter />

	<PageWrapper/>
	</body>
</html>