---

import '../styles/global.css';
import Navigation from '../components/navigation.astro'
import ContextSectionFooter from '../components/context-section-footer.astro';
import PageWrapper from '../components/page-wrapper.astro';
import ContextSection from '../components/context-section.astro';
import BackButton from '../components/back-button.astro';
import WhatWhyLayout from '../components/what-why-layout.astro';


const pageTitle = "What / Why — Middle Ground Made";



---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="icon" href="/favicon.ico?v=2" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

		<meta property="og:title" content="Middle Ground Made" />
		<meta property="og:description" content="Heirloom design studio." />
		<meta property="og:image" content="https://middlegroundmade.com/mg-social-share.webp" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Middle Ground Made" />
		<meta name="twitter:description" content="Heirloom design studio." />
		<meta name="twitter:image" content="https://middlegroundmade.com/mg-social-share.webp" />
	</head>
	<body>
	<PageWrapper>
		<Navigation />
		<ContextSection>
			<h2>What / Why</h2>
			<hr>
    		<p> 
   			Maybe one day this collection will include more interesting responses to questions like "who" and "how" and "when." Because currently, the asnwer answers would be: me, Mikey Hayes, I have no idea, and since 2019.
    		</p>
			<p class="note"> * Here's the details </p>

		</ContextSection>
			
		<ContextSection>				
			<WhatWhyLayout />
			<BackButton/>
		</ContextSection>
		<ContextSectionFooter />
	<PageWrapper/>
	</body>
</html>


