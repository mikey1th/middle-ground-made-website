---

import '../styles/global.css';
import Navigation from '../components/navigation.astro'
import ContextSectionFooter from '../components/context-section-footer.astro';
import PageWrapper from '../components/page-wrapper.astro';
import ContextSection from '../components/context-section.astro';
import BackButton from '../components/back-button.astro';
import GalleryLayout from '../components/gallery-layout.astro';
import { getCollection } from 'astro:content';
const additions = await getCollection('gallery');


const pageTitle = "Gallery — Middle Ground Made";


---


<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="icon" href="/favicon.ico?v=2" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

		<meta property="og:title" content="Middle Ground Made" />
		<meta property="og:description" content="Heirloom design studio." />
		<meta property="og:image" content="https://middlegroundmade.com/mg-social-share.webp" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Middle Ground Made" />
		<meta name="twitter:description" content="Heirloom design studio." />
		<meta name="twitter:image" content="https://middlegroundmade.com/mg-social-share.webp" />
	</head>
	<body>
	<PageWrapper>
	<Navigation />

	<ContextSection>
	<h2>Gallery</h2>
	<hr>
	<p> Here's a collection of images that are too good not to share, most were captured by me, others are too sentimental to not out on display. </p>
    <p class="note">
    [{additions.length}] Pics In order from newest to oldest
    </p>
	</ContextSection>

	<ContextSection>
	<GalleryLayout/>
	<BackButton/>
	</ContextSection>
	
	<ContextSectionFooter />

	<PageWrapper/>
	</body>
</html>