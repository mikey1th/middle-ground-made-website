---

import '../styles/global.css';
import Navigation from '../components/navigation.astro'
import ContextSectionFooter from '../components/context-section-footer.astro';
import PageWrapper from '../components/page-wrapper.astro';
import ContextSection from '../components/context-section.astro';
import BackButton from '../components/back-button.astro';
import ResourcesCollection from '../components/resources-collection.astro';

import resources from "../data/resources-data.js";
const count = resources.length;

const pageTitle = "Resources — Middle Ground Made";


---


<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="icon" href="/favicon.ico?v=2" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

		<meta property="og:title" content="Middle Ground Made" />
		<meta property="og:description" content="Heirloom design studio." />
		<meta property="og:image" content="https://middlegroundmade.com/mg-social-share.webp" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Middle Ground Made" />
		<meta name="twitter:description" content="Heirloom design studio." />
		<meta name="twitter:image" content="https://middlegroundmade.com/mg-social-share.webp" />
	</head>
	<body>
	<PageWrapper>
	<Navigation />
	<ContextSection>
	<h2>Resources</h2>
	<hr>
	<p> 
		Resources are shared monthly in the Ground Up Newsletter, and are things I find remarkable, helpful, or sometimes just cool. Since these links are only shared once a month I prioritize quality over quantity. 
    </p>
	<hr>
	<p> 		
		Not every resource is listed here, but the collecion below will give you an idea of the sort of things that make the cut! To see the full list of resources explore the newsletter <a href= "https://middle-ground-made.kit.com/profile" target="_blank" rel="noopener noreferrer" class="body-link"> archive. </a> 
    </p>
	<p class="note">
    [{count}] Links incoming
    </p>
	</ContextSection>

	<ContextSection>
	<ResourcesCollection/>
	<hr>
	<BackButton/>	
	</ContextSection>
	<ContextSectionFooter/>
	</PageWrapper>
	
	</body>
</html>