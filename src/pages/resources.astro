---

import '../styles/global.css';
import Navigation from '../components/navigation.astro'
import ContextSectionFooter from '../components/context-section-footer.astro';
import PageWrapper from '../components/page-wrapper.astro';
import ContextSection from '../components/context-section.astro';
import BackButton from '../components/back-button.astro';
import ResourcesCollection from '../components/resources-collection.astro';


const pageTitle = "Resources";


---


<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="icon" href="/favicon.ico?v=2" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
	</head>
	<body>
	<PageWrapper>
	<Navigation />
	<ContextSection>
	<h2>{pageTitle}</h2>
	<hr>
	<p> 
		Resources are shared monthly in the Midde Ground Newsletter. Over the years I've found some pretty
		remarkable stuff. Somtimes its a simple quote, other times a video, other times an object or even a website.
		If you love rabbit holes, and cool stuff you'll enjoy the collection below!
    </p>
	<p class="note">
    * Links incoming
    </p>
	</ContextSection>

	<ContextSection>
	<ResourcesCollection/>
	<hr>
	<BackButton/>	
	</ContextSection>
	<ContextSectionFooter/>
	</PageWrapper>
	
	</body>
</html>