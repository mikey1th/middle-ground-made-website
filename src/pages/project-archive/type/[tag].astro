---

import '../../../styles/global.css';
import Navigation from '../../../components/navigation.astro'
import Footer from '../../../components/footer.astro'
import PageWrapper from '../../../components/page-wrapper.astro';
import ContextSection from '../../../components/context-section.astro';
import BackButton from '../../../components/back-button.astro';
import { Image } from 'astro:assets';

import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths () {
    const projects = await getCollection ('projects');
    const allTags = [...new Set(projects.flatMap(p => p.data.tags))]
    return allTags.map (tag => ({
    params: { tag },
    props:  {
    projects: projects.filter(p =>p.data.tags.includes(tag)).sort((a, b) => new Date(b.data.sortDate).getTime() - new Date(a.data.sortDate).getTime())
        
    }
    }));
}

const { tag }= Astro.params;
const { projects } = Astro.props;

const pageTitle = tag;

const tagDescriptions : Record<string, string> = {
  "books": "Every book in this category has been painstakingly writted, editd, designed, and published by me",
  "objects": "Objects often start out as digital files but find thier way to the physical world.",
  "paintings": "I didn't plan on liking painting as much as I do, it just kinda...happened. Either way, I love this shit. And I plan onpainting as many things as I can",

}

---


<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
	<PageWrapper>
	<Navigation />
	<ContextSection>
	<h2>{pageTitle}</h2>
	<hr>
    {tagDescriptions[pageTitle] && <p>{tagDescriptions[pageTitle]}</p>} {/* Tells this <p> element to render the text associate with each tag */}
	<p class="note"> * Explore {projects.length} entires </p>
    </ContextSection>

    <ContextSection>
    <div class="all-project-additions">
        {projects.map((project) => (
            <div class="project-entry"> 
                    {/* the div below renders the unconditonal header info */}
                    <div class="project-header-info">
                        <div class="content-bubble">
                            <span> {project.data.title} </span>
                            <span class="link-details header"> / </span>
                            <span class="link-details header"> {project.data.date} </span>
                            <span class="link-details header"> / </span>
                            <span class="link-details header"> {project.data.id} </span>
                        </div>
                    </div>
                    <a href={`/project-archive/${project.slug}`}>
                    <Image src={project.data.coverImage} alt={project.data.title} />    
                    </a>
                </div>
        ))}
    </div>
    <BackButton/>
	</ContextSection>
	<Footer />
	</PageWrapper >
	</body>





<style>
    .all-project-additions{
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 40px
    }

    .project-entry{
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 20px;
    border-bottom: 1px solid #E8E8E8;
    padding-bottom: 20px;
    }

    .project-entry img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    transition: filter 0.3s ease;
    outline: 1px solid rgba(0, 0, 0, 0.1);
    outline-offset: -1px;
    }

    .project-entry img:hover {
    filter: brightness(0.85);
    }

    h3 {
    font-size: .90rem;
    font-weight: 400;
    }

    .project-header-info{
    display: inline-flex;
    gap: 10px;
    width: fit-content;
    }

    .link-details{
    color: #2d2d2d;
    }

    .link-details:hover{
    font-weight: 500;
    color: #2d2d2d;
    }

    .link-details.header:hover{
    pointer-events: none;
    font-weight: 300;
    }

    .content-links{
    text-transform: capitalize;
    }

    .content-links:hover{
    cursor: default;
    background: #FAFAFA;
    }


</style>