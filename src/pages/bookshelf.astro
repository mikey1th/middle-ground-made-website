---

import '../styles/global.css';
import Navigation from '../components/navigation.astro'
import ContextSectionFooter from '../components/context-section-footer.astro';
import PageWrapper from '../components/page-wrapper.astro';
import ContextSection from '../components/context-section.astro';
import BackButton from '../components/back-button.astro';
import BookshelfLayout from '../components/bookshelf-layout.astro';

import bookshelf from "../data/bookshelf-data.js";
const count = bookshelf.length;


const pageTitle = "Bookshelf";


---


<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="icon" href="/favicon.ico?v=2" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
	</head>
	<body>
	<PageWrapper>
	<Navigation />
	<ContextSection>
	<h2>{pageTitle}</h2>
	<hr>
	<p> 
		This is a perpetually incomplete collection of the books I've read and can full-heartedly reccomend. This is also living archive, so come back for updates / additions.
    </p>
	<p class="note">
    [{count}] Recommendations below 
    </p>
	</ContextSection>

	<ContextSection>
	<BookshelfLayout/>
    <hr>
	<BackButton/>
	</ContextSection>

	<ContextSectionFooter/>
	</PageWrapper>
	</body>
</html>